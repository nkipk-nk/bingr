# TMDB API
VITE_TMDB_API_KEY=your_tmdb_api_key

# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry (get DSN from sentry.io → your project → Settings → Client Keys)
VITE_SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/123456

# IntaSend (get from intasend.com → Settings → API Keys → Publishable Key)
VITE_INTASEND_PUBLISHABLE_KEY=your_intasend_publishable_key
